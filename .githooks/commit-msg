#!/bin/bash
# ECOS Commit-msg Hook - Validation
# Version: 1.0.0 | IntentHash: 0xECOS_HOOK_MSG_20260403

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Conventional commits format: type(scope): description
# Types: feat, fix, docs, refactor, test, chore, perf, ci, build

VALID_TYPES="feat|fix|docs|refactor|test|chore|perf|ci|build|style|revert"

if ! echo "$COMMIT_MSG" | grep -qE "^[a-z]+(\(.+\))?: "; then
    echo ""
    echo "[ERROR] Commit message does not follow conventional commits format"
    echo "Expected: type(scope): description"
    echo "Valid types: $VALID_TYPES"
    echo ""
    echo "Example: feat(ecos): add registry scanner"
    echo "Example: fix(blo): resolve audit failure"
    echo ""
    exit 1
fi

echo "[OK] Commit message follows conventional format"
exit 0
